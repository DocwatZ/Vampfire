# Vampfire Configuration
# Copy this file to .env and edit as needed.
# See .env.production for a fully documented production example.

# =============================================================================
# Rails
# =============================================================================

# Rails secret key (required — generate with: openssl rand -hex 64)
SECRET_KEY_BASE=

# =============================================================================
# LiveKit (Voice / Video / Screen Share)
# =============================================================================

# Public-facing WebSocket URL for LiveKit.
# ⚠️  Must be reachable by end-user browsers, not just Docker internal network.
# - Use ws://  for local/HTTP development
# - Use wss:// when behind a reverse proxy with SSL (required for production)
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_SECRET=secret

# =============================================================================
# Redis
# =============================================================================

REDIS_URL=redis://redis:6379

# =============================================================================
# SSL
# =============================================================================

# Set DISABLE_SSL=true to serve over plain HTTP (e.g., behind a reverse proxy)
# Set SSL_DOMAIN=your.domain.com for automatic Let's Encrypt SSL
DISABLE_SSL=true
# SSL_DOMAIN=

# =============================================================================
# TURN Server (optional — required for reliable voice/video across NATs)
# =============================================================================

# See docs/NETWORKING.md for when and why you need a TURN server.
# TURN_HOST=turn.yourdomain.com
# TURN_PORT=3478
# TURN_USERNAME=vampfire
# TURN_PASSWORD=

# =============================================================================
# Web Push Notifications (optional)
# =============================================================================

# Generate with: script/admin/create-vapid-key
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# =============================================================================
# Error Reporting (optional)
# =============================================================================

# SENTRY_DSN=
