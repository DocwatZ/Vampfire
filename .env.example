# Vampfire Configuration
# Copy this file to .env and edit as needed

# Rails secret key (required - generate with: openssl rand -hex 64)
SECRET_KEY_BASE=

# LiveKit Configuration
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_SECRET=secret

# Redis Configuration
REDIS_URL=redis://redis:6379

# SSL Configuration
# Set DISABLE_SSL=true to serve over plain HTTP
# Set SSL_DOMAIN=your.domain.com for automatic Let's Encrypt SSL
DISABLE_SSL=true
# SSL_DOMAIN=

# Web Push Notifications (optional)
# Generate with: script/admin/create-vapid-key
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Error Reporting (optional)
# SENTRY_DSN=
