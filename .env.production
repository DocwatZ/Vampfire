# Vampfire Production Environment Configuration
# Copy this file to .env and edit ALL values before deploying.
#
# ⚠️  DO NOT use default values in production — generate strong, unique secrets.

# =============================================================================
# REQUIRED — Rails
# =============================================================================

# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64

# =============================================================================
# REQUIRED — LiveKit (Voice / Video / Screen Share)
# =============================================================================

# Public-facing WebSocket URL for LiveKit.
# - Use ws:// for local/HTTP access (development only)
# - Use wss:// when behind a reverse proxy with SSL (required for production)
#
# This URL must be reachable by end-user browsers, NOT just the Docker network.
# Example: wss://livekit.yourdomain.com
LIVEKIT_URL=wss://livekit.yourdomain.com

# LiveKit API credentials — must match keys in livekit.yaml
# Generate a strong key:    openssl rand -hex 16
# Generate a strong secret: openssl rand -hex 32
LIVEKIT_API_KEY=CHANGE_ME
LIVEKIT_SECRET=CHANGE_ME

# =============================================================================
# REQUIRED — Redis
# =============================================================================

REDIS_URL=redis://redis:6379

# =============================================================================
# SSL Configuration
# =============================================================================

# Set to "true" if a reverse proxy (Nginx Proxy Manager, Cloudflare, SWAG)
# handles SSL termination. Set to blank/remove to let Rails enforce SSL.
DISABLE_SSL=true

# =============================================================================
# OPTIONAL — TURN Server (for NAT traversal)
# =============================================================================

# A TURN server is required for reliable voice/video across:
# - Symmetric NATs (common in corporate networks)
# - Mobile networks (4G/5G)
# - Restrictive firewalls
#
# If you have an existing Coturn server, configure these:
# TURN_HOST=turn.yourdomain.com
# TURN_PORT=3478
# TURN_USERNAME=vampfire
# TURN_PASSWORD=CHANGE_ME

# =============================================================================
# OPTIONAL — Web Push Notifications
# =============================================================================

# Generate with:
#   docker run --rm ghcr.io/docwatz/vampfire:latest \
#     bin/rails runner "keys = WebPush.generate_key; puts keys.public_key; puts keys.private_key"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
